{
  "expo": {
    "name": "GymBuddy",
    "slug": "gymbuddy",
    "version": "1.0.0",
    "scheme": "gymbuddy",
    "sdkVersion": "54.0.0",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GymBuddy to use your location to find nearby gyms."
        }
      ]
    ],
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    }
  }
}